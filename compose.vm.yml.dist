# VM-only stack used by Vagrant. Brings up Traefik on :443 with the local
# mkcert cert so https://weleda-webcenter-text-export.test routes to either
# the dev container (Vite) or the prod SSR container, depending on which
# profile you bring up.
#
# This file is the dist/template; the Vagrantfile copies it to
# `compose.vm.yml` on first boot. Edit `compose.vm.yml` (gitignored) for
# local customisation, or this file for project-wide changes.
#
# Bring up dev:  docker compose -f compose.vm.yml --profile dev up
# Bring up prod: docker compose -f compose.vm.yml --profile prod up

services:
  dev:
    build:
      context: .
      dockerfile: Dockerfile
      target: base
    profiles: [dev]
    container_name: weleda-dev
    working_dir: /app
    command: sh -c "pnpm install && pnpm run dev --host 0.0.0.0"
    volumes:
      - .:/app
      - node_modules:/app/node_modules
      - ~/data/pnpm:/var/cache/pnpm
    environment:
      NODE_ENV: development
    depends_on: [traefik]
    labels:
      traefik.enable: 'true'
      traefik.http.routers.dev.entrypoints: websecure
      traefik.http.routers.dev.rule: Host(`weleda-webcenter-text-export.test`)
      traefik.http.routers.dev.tls: 'true'
      traefik.http.services.dev.loadbalancer.server.port: '5173'

  prod:
    build:
      context: .
      dockerfile: Dockerfile
      target: runtime
    profiles: [prod]
    container_name: weleda-prod
    depends_on: [traefik]
    labels:
      traefik.enable: 'true'
      traefik.http.routers.prod.entrypoints: websecure
      traefik.http.routers.prod.rule: Host(`weleda-webcenter-text-export.test`)
      traefik.http.routers.prod.tls: 'true'
      traefik.http.services.prod.loadbalancer.server.port: '3000'

  traefik:
    image: traefik
    profiles: [dev, prod]
    init: true
    command:
      - --api.insecure=true
      - --api.dashboard=true
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.file.directory=/etc/traefik/dynamic_conf
      - --providers.file.watch=true
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entryPoint.to=websecure
      - --entrypoints.web.http.redirections.entryPoint.scheme=https
      - --entrypoints.web.http.redirections.entrypoint.permanent=true
      - --entrypoints.websecure.address=:443
    ports:
      - '80:80'
      - '443:443'
      - '8080:8080'
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./.docker/certs:/etc/ssl/certs/local:ro
      - ./.docker/rootfs-local/traefik/etc/traefik/dynamic_conf/conf.yml:/etc/traefik/dynamic_conf/conf.yml:ro
    labels:
      traefik.enable: 'true'
      traefik.http.routers.traefik.entrypoints: websecure
      traefik.http.routers.traefik.rule: Host(`traefik.weleda-webcenter-text-export.test`)
      traefik.http.routers.traefik.tls: 'true'
      traefik.http.routers.traefik.service: api@internal

volumes:
  node_modules:
